		"test:visual:update": "npx playwright test visual-regression --update-snapshots",
		"gen-types": "supabase gen types typescript --project-id iybfarqvntkkfxwbrxll --schema public > src/lib/database.types.generated.ts",
		"load-test": "k6 run k6/search-browse-load.js",
		"load-test:sync": "k6 run k6/daily-sync-upsert-load.js",
		"prepare": "git -C .. config core.hooksPath khayal/.husky && chmod +x .husky/pre-push"
	},
