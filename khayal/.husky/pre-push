#!/usr/bin/env sh
# pre-push: Gate 9 — full cumulative regression from cold state (fixes #325)
#           Gate 13 — visual regression snapshots on UI component changes (fixes #326)
# Runs pnpm verify (tsc + eslint + vitest + playwright) as a hard block.
# No partial green. All tests must pass, zero skips allowed.

REPO_ROOT="$(git rev-parse --show-toplevel)"
PROJECT_DIR="$REPO_ROOT/khayal"

# Support both monorepo layout (../khayal) and standalone repo
if [ ! -f "$PROJECT_DIR/package.json" ]; then
  PROJECT_DIR="$REPO_ROOT"
fi

cd "$PROJECT_DIR" || exit 1

# ── Gate 13: Visual Regression (Lost Pixel / Playwright snapshots) ─────────────
# Triggered only when UI component files changed in the push.
UI_CHANGED=$(git diff --name-only HEAD~1 HEAD 2>/dev/null | grep -E \
  '(src/components/|src/app/.*/page\.tsx|src/app/.*/layout\.tsx|globals\.css|tailwind)' \
  | wc -l | tr -d ' ')

if [ "$UI_CHANGED" -gt "0" ]; then
  echo ""
  echo "======================================================="
  echo "  Gate 13: Visual regression snapshots"
  echo "  UI files changed: $UI_CHANGED file(s)"
  echo "  Running: npx playwright test visual-regression"
  echo "======================================================="
  echo ""

  node "$(node -e "require.resolve('@playwright/test/cli')")" test visual-regression
  VISUAL_STATUS=$?

  if [ $VISUAL_STATUS -ne 0 ]; then
    echo ""
    echo "======================================================="
    echo "  PUSH BLOCKED -- Gate 13 (visual regression) failed."
    echo ""
    echo "  If this is expected (intentional UI change):"
    echo "    node "$(node -e "require.resolve('@playwright/test/cli')")" test visual-regression --update-snapshots"
    echo "    git add e2e/__snapshots__"
    echo "    git commit -m 'chore: update visual snapshots'"
    echo "======================================================="
    exit 1
  fi

  echo ""
  echo "  Gate 13 passed."
  echo ""
fi

# ── Gate 9: Full cumulative regression ─────────────────────────────────────────
echo ""
echo "======================================================="
echo "  Gate 9: Full cumulative regression (pnpm verify)"
echo "  Zero test failures. Zero skips allowed."
echo "======================================================="
echo ""

# Run full verify suite
pnpm verify
VERIFY_STATUS=$?

if [ $VERIFY_STATUS -ne 0 ]; then
  echo ""
  echo "======================================================="
  echo "  PUSH BLOCKED -- Gate 9 failed."
  echo "  Fix all test failures before pushing."
  echo "  Run: pnpm verify"
  echo "  To inspect: npx vitest run --reporter=verbose"
  echo "======================================================="
  exit 1
fi

# Check for skipped tests (vitest outputs "X skipped")
SKIP_COUNT=$(pnpm vitest run --reporter=json 2>/dev/null | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    skipped = sum(s.get('skipped', 0) for s in data.get('testResults', []))
    print(skipped)
except Exception:
    print(0)
" 2>/dev/null || echo "0")

if [ "$SKIP_COUNT" -gt "0" ] && [ "$ALLOW_SKIPS" != "1" ]; then
  echo ""
  echo "======================================================="
  echo "  PUSH BLOCKED -- $SKIP_COUNT skipped test(s) detected."
  echo "  Fix skipped tests or set ALLOW_SKIPS=1 (requires"
  echo "  justification in commit message)."
  echo "======================================================="
  exit 1
fi

echo ""
echo "======================================================="
echo "  Gate 9 passed. Push allowed."
echo "======================================================="
echo ""
