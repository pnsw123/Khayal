# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Server-side URL (no NEXT_PUBLIC_ prefix) — used only by Python sync scripts and
# GitHub Actions (daily-sync.yml). Must be added as a separate GitHub secret named
# SUPABASE_URL. Value is identical to NEXT_PUBLIC_SUPABASE_URL above.
SUPABASE_URL=https://your-project.supabase.co

# TMDB — get your key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key-here
# Number of TMDB trending pages to fetch per media type (default: 3, max recommended: 10).
# Each page contains ~20 results.  Increase for larger catalogs; reduce to stay well under
# the TMDB rate limit (40 requests / 10 s for authenticated requests).
TMDB_MAX_PAGES=3

# Upstash Redis — required for distributed rate limiting in production.
# Create a free database at https://console.upstash.com → copy REST API URL and token.
# Without these the /auth/callback rate limiter is DISABLED (dev-mode fallback).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token-here

# Supabase CLI access token — required for gen-types CI workflow and local type generation.
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-supabase-pat-here
